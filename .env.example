# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Groq API key (same one used across Phase 2 projects)
GROQ_API_KEY=

# Groq model key: "gpt-oss" (default) or "llama"
GROQ_MODEL=gpt-oss

# Your numeric Telegram id (from @userinfobot) — bypasses rate limit, unlocks admin commands
ADMIN_TELEGRAM_ID=

# SQLite database path
DATABASE_PATH=./data/bot.db
